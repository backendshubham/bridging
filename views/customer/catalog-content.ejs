<div class="page active" id="page-catalog">
  <div class="catalog-hero">
    <div class="section-eyebrow">Our Inventory</div>
    <h1>💎 Gemstone Collection</h1>
    <p>Discover our exquisite collection of certified gemstones with complete transparency and authenticity</p>
  </div>

  <div class="catalog-body">
    <!-- FILTERS -->
    <aside class="filter-panel">
      <div class="filter-header">
        <h3>⚗️ Filters</h3>
        <button class="clear-btn" onclick="clearFilters()">Clear All</button>
      </div>
      <div class="filter-group">
        <label class="filter-label">Search Gemstones</label>
        <input class="filter-input" type="text" placeholder="Search by name, type, or origin…" id="searchFilter" oninput="filterGems()">
      </div>
      <div class="filter-group">
        <label class="filter-label">Ratna Type</label>
        <select class="filter-input" id="typeFilter" onchange="filterGems()">
          <option value="">All Types</option>
          <% if (typeof ratnaTypes !== 'undefined' && ratnaTypes) { %>
            <% ratnaTypes.forEach(function(type) { %>
              <option value="<%= type %>"><%= type %></option>
            <% }); %>
          <% } %>
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label">Category</label>
        <select class="filter-input" id="catFilter" onchange="filterGems()">
          <option value="">All Categories</option>
          <% if (typeof categories !== 'undefined' && categories) { %>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat.name %>"><%= cat.name %></option>
            <% }); %>
          <% } %>
        </select>
      </div>
      <div class="filter-group">
        <label class="filter-label">Min Carat</label>
        <input class="filter-input" type="number" placeholder="0" id="caratFilter" min="0" step="0.1" oninput="filterGems()">
      </div>
    </aside>

    <!-- GEMS GRID -->
    <div class="gems-area">
      <div class="gems-toolbar">
        <p class="gems-count">Showing <strong id="gemCount">0</strong> gemstones</p>
      </div>
      <div class="gems-grid" id="gemsGrid"></div>
    </div>
  </div>
</div>

<script>
// ─── DYNAMIC DATA FROM SERVER ───
const RAW_GEMS = <%- JSON.stringify(gemstones) %>;

// ─── HELPER FOR TYPE COLOR ───
function getTypeColorClass(type) {
  const t = (type || '').toLowerCase();
  if (t.includes('manik') || t.includes('ruby')) return 'bg-ruby';
  if (t.includes('neelam') || t.includes('sapphire')) return 'bg-sapphire';
  if (t.includes('panna') || t.includes('emerald')) return 'bg-emerald';
  if (t.includes('heera') || t.includes('diamond')) return 'bg-diamond';
  if (t.includes('pukhraj') || t.includes('yellow')) return 'bg-topaz';
  if (t.includes('katela') || t.includes('amethyst')) return 'bg-amethyst';
  return 'bg-diamond';
}

// ─── HELPER FOR EMOJI ───
function getTypeEmoji(type) {
  const t = (type || '').toLowerCase();
  if (t.includes('manik') || t.includes('ruby')) return '❤️‍🔥';
  if (t.includes('neelam') || t.includes('sapphire')) return '💙';
  if (t.includes('panna') || t.includes('emerald')) return '💚';
  if (t.includes('heera') || t.includes('diamond')) return '💎';
  if (t.includes('pukhraj') || t.includes('yellow')) return '💛';
  if (t.includes('katela') || t.includes('amethyst')) return '💜';
  return '💎';
}

const GEMS = RAW_GEMS.map(g => ({
  id: g.sku,
  name: g.name,
  type: g.ratna_type,
  cat: g.category_name || 'Gemstones',
  carat: parseFloat(g.carat_weight),
  color: g.color_grade || 'Natural',
  clarity: g.clarity || 'Standard',
  price: parseFloat(g.final_price),
  emoji: getTypeEmoji(g.ratna_type),
  bg: getTypeColorClass(g.ratna_type),
  cert: g.certificate_type || 'Certified',
  sku: g.sku
}));

let filtered = [...GEMS];

// ─── RENDER ───
function renderGems() {
  const grid = document.getElementById('gemsGrid');
  const count = document.getElementById('gemCount');
  if (!grid || !count) return;
  
  count.textContent = filtered.length;
  grid.innerHTML = filtered.map(g => `
    <div class="gem-listing-card" onclick="window.location.href='/product/${g.sku}'">
      <div class="gem-listing-img ${g.bg} gem-shimmer">${g.emoji}</div>
      <div class="gem-listing-body">
        <div class="gem-listing-name">${g.name}</div>
        <div class="gem-listing-tags">
          <span class="tag tag-type">${g.type}</span>
          <span class="tag" style="background:rgba(11,12,26,.06);color:var(--txt-lt)">${g.carat} ct</span>
          <span class="tag" style="background:rgba(11,12,26,.06);color:var(--txt-lt)">${g.clarity}</span>
        </div>
        <div class="gem-listing-price">₹${g.price.toLocaleString('en-IN')}</div>
        <div class="cert-badge">✓ ${g.cert} Certified</div>
      </div>
    </div>
  `).join('');
}

// ─── FILTER ───
function filterGems() {
  const search = document.getElementById('searchFilter').value.toLowerCase();
  const type = document.getElementById('typeFilter').value;
  const cat = document.getElementById('catFilter').value;
  const minCarat = parseFloat(document.getElementById('caratFilter').value) || 0;
  
  filtered = GEMS.filter(g =>
    (g.name.toLowerCase().includes(search) || g.type.toLowerCase().includes(search) || g.sku.toLowerCase().includes(search)) &&
    (type === '' || g.type === type) &&
    (cat === '' || g.cat === cat) &&
    g.carat >= minCarat
  );
  renderGems();
}

function clearFilters() {
  document.getElementById('searchFilter').value = '';
  document.getElementById('typeFilter').value = '';
  document.getElementById('catFilter').value = '';
  document.getElementById('caratFilter').value = '';
  filtered = [...GEMS];
  renderGems();
}

// ─── INIT ───
document.addEventListener('DOMContentLoaded', () => {
    // Check for query params (e.g. from homepage hero clicks)
    const urlParams = new URLSearchParams(window.location.search);
    const type = urlParams.get('type');
    if (type) {
        const typeSelect = document.getElementById('typeFilter');
        if (typeSelect) {
            typeSelect.value = type;
            filterGems();
        }
    }
    renderGems();
});
</script>
