<div class="page active" id="page-contact">
    <div class="contact-hero">
        <div class="contact-hero-icon">💎</div>
        <h1>Get In Touch</h1>
        <p>Experience the luxury of authentic gemstones. Visit our store or connect with us through any channel below.</p>
        <div class="contact-divider"><span>✦</span></div>
    </div>

    <div class="contact-body">
        <div class="contact-cards">
            <div class="contact-card">
                <div class="contact-card-icon">🏪</div>
                <h3>Visit Our Store</h3>
                <p><%= settings.shop_address || 'Come see our gemstone collection in person and experience the quality firsthand.' %></p>
                <a href="#map-section">View on Map →</a>
            </div>
            <div class="contact-card">
                <div class="contact-card-icon">📞</div>
                <h3>Call Us</h3>
                <p>Speak directly with our gemstone experts for personalized guidance.</p>
                <% if (settings.contact_phone) { %>
                    <a href="tel:<%= settings.contact_phone %>"><%= settings.contact_phone %></a>
                <% } else { %>
                    <a href="tel:+919876543210">+91 98765 43210</a>
                <% } %>
            </div>
            <div class="contact-card">
                <div class="contact-card-icon">✉️</div>
                <h3>Email Us</h3>
                <p>Send us your queries and we'll respond within 24 hours.</p>
                <% if (settings.contact_email) { %>
                    <a href="mailto:<%= settings.contact_email %>"><%= settings.contact_email %></a>
                <% } else { %>
                    <a href="mailto:info@ratnaveda.com">info@ratnaveda.com</a>
                <% } %>
            </div>
            <div class="contact-card">
                <div class="contact-card-icon">🕐</div>
                <h3>Business Hours</h3>
                <p>
                    <% if (settings.business_hours) { %>
                        <%- settings.business_hours.replace(/\n/g, '<br>') %>
                    <% } else { %>
                        Monday – Saturday<br><strong>10:00 AM – 7:00 PM</strong><br>Sunday: Closed
                    <% } %>
                </p>
            </div>
        </div>

        <!-- MAP -->
        <div class="map-section" id="map-section">
            <h2>Find Us</h2>
            <p class="sub">Visit our store location for an in-person experience</p>
            
            <% if (typeof googleMapsApiKey !== 'undefined' && googleMapsApiKey) { %>
                <div id="map" style="height: 450px; width: 100%; border-radius: var(--r-md); border: 1px solid rgba(201,152,58,.15); margin-bottom: 24px;"></div>
                <script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&callback=initMap" async defer></script>
            <% } else { %>
                <div class="map-placeholder">
                    <div class="map-icon">🗺️</div>
                    <h3>Map Unavailable</h3>
                    <p>Please contact us for directions to our store. Configure Google Maps API key in admin settings to enable.</p>
                </div>
            <% } %>

            <div class="map-info">
                <div class="map-info-icon">📍</div>
                <div>
                    <strong>RatnaVeda</strong>
                    <span><%= settings.shop_address || 'Address not available — contact us for directions' %></span>
                </div>
            </div>
        </div>

        <!-- WHY VISIT -->
        <div class="why-visit">
            <h2>Why Visit Us?</h2>
            <p class="sub">Experience the difference of authentic luxury</p>
            <div class="why-visit-grid">
                <div class="why-visit-card">
                    <div class="icon">💎</div>
                    <h3>Authentic Gemstones</h3>
                    <p>View our certified collection in person and feel the quality that sets us apart.</p>
                </div>
                <div class="why-visit-card">
                    <div class="icon">👨‍💼</div>
                    <h3>Expert Consultation</h3>
                    <p>Get professional guidance from our gemstone experts during your visit.</p>
                </div>
                <div class="why-visit-card">
                    <div class="icon">📜</div>
                    <h3>Certification</h3>
                    <p>All gemstones come with proper certification and complete documentation.</p>
                </div>
                <div class="why-visit-card">
                    <div class="icon">🛡️</div>
                    <h3>Trusted Quality</h3>
                    <p>Years of expertise in authentic gemstone trading and customer satisfaction.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (typeof googleMapsApiKey !== 'undefined' && googleMapsApiKey) { %>
<script>
function initMap() {
    const location = { 
        lat: parseFloat('<%= settings.map_latitude || "28.6139" %>'), 
        lng: parseFloat('<%= settings.map_longitude || "77.2090" %>') 
    };
    const map = new google.maps.Map(document.getElementById('map'), {
        zoom: 15,
        center: location,
        styles: [
            { featureType: 'poi', elementType: 'labels', stylers: [{ visibility: 'off' }] }
        ]
    });
    new google.maps.Marker({
        position: location,
        map: map,
        title: '<%= settings.shop_name || "RatnaVeda" %>'
    });
}
</script>
<% } %>


