<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('../partials/head') %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Jost:wght@300;400;500;600&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/customer.css">
    <link rel="stylesheet" href="/css/toast.css">
    <title><%= typeof title !== 'undefined' ? title : 'RatnaVeda - Precious Gems' %></title>
</head>
<body>
    <nav id="mainNav">
        <a class="nav-logo" href="/">
            <div class="nav-logo-gem"></div>
            Ratna<span>Veda</span>
        </a>
        <ul class="nav-links">
            <li><a href="/" id="nav-home" class="<%= typeof currentPage !== 'undefined' && currentPage === 'home' ? 'active' : '' %>">Home</a></li>
            <li><a href="/catalog" id="nav-catalog" class="<%= typeof currentPage !== 'undefined' && currentPage === 'catalog' ? 'active' : '' %>">Catalog</a></li>
            <li><a href="/contact" id="nav-contact" class="<%= typeof currentPage !== 'undefined' && currentPage === 'contact' ? 'active' : '' %>">Contact</a></li>
        </ul>
    </nav>

    <% if (typeof contentFile !== 'undefined') { %>
        <%- include('./' + contentFile.replace('customer/', '')) %>
    <% } else if (typeof body !== 'undefined') { %>
        <%- body %>
    <% } %>

    <footer>
        <div class="footer-inner">
            <div class="footer-grid">
                <div class="footer-brand">
                    <a class="nav-logo" href="/" style="color: #fff; margin-bottom: 16px;">
                        <div class="nav-logo-gem"></div>
                        Ratna<span>Veda</span>
                    </a>
                    <p>Next-Gen Gemstone Inventory & QR Discovery System. Bringing authenticity and transparency to the world of precious gems.</p>
                </div>
                <div class="footer-col">
                    <h4>Quick Links</h4>
                    <ul>
                        <li><a href="/catalog">Browse Catalog</a></li>
                        <li><a href="/privacy-policy">Privacy Policy</a></li>
                        <li><a href="/terms-conditions">Terms & Conditions</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Contact</h4>
                    <ul>
                        <li><a href="/contact">Visit our store to see gemstones in person</a></li>
                        <li><a href="/contact">Contact Us</a></li>
                        <li><a href="mailto:info@ratnaveda.com">info@ratnaveda.com</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">© <%= new Date().getFullYear() %> RatnaVeda. All rights reserved. Crafted with ✦ for gem lovers.</div>
        </div>
    </footer>

    <script src="/js/customer.js"></script>
    <script src="/js/toast.js"></script>
    <script>
        window.addEventListener('scroll', () => {
            document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY > 10);
        });
    </script>
</body>
</html>
