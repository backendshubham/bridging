<div class="page active" id="page-detail">
  <div class="detail-page">
    <div class="detail-inner">
      <a href="/catalog" class="back-btn">← Back to Catalog</a>
      <div class="detail-grid">
        <!-- Image Gallery -->
        <div class="detail-gallery">
          <% 
            let primaryImg = gemstone.primary_image || '/img/placeholder-gem.png';
            let allImages = [];
            if (gemstone.primary_image) allImages.push(gemstone.primary_image);
            if (gemstone.image_gallery && Array.isArray(gemstone.image_gallery)) {
              allImages = allImages.concat(gemstone.image_gallery);
            }
            
            // Map ratna type to gradient class
            const ratnaToClass = {
              'Manik': 'bg-ruby',
              'Ruby': 'bg-ruby',
              'Neelam': 'bg-sapphire',
              'Sapphire': 'bg-sapphire',
              'Panna': 'bg-emerald',
              'Emerald': 'bg-emerald',
              'Heera': 'bg-diamond',
              'Diamond': 'bg-diamond',
              'Pukhraj': 'bg-topaz',
              'Yellow Sapphire': 'bg-topaz',
              'Amethyst': 'bg-amethyst',
              'Pearl': 'bg-diamond'
            };
            const bgClass = ratnaToClass[gemstone.ratna_type] || 'bg-diamond';
          %>
          <div class="detail-main-img <%= bgClass %> gem-shimmer" id="detailMainImg">
            <% if (gemstone.primary_image) { %>
              <img src="<%= gemstone.primary_image %>" alt="<%= gemstone.name %>" style="max-width: 100%; max-height: 100%; object-fit: contain; position: relative; z-index: 2;">
            <% } else { %>
              <div style="font-size: 7rem;">💎</div>
            <% } %>
          </div>
          
          <% if (allImages.length > 1) { %>
            <div class="detail-thumbnails" id="detailThumbs">
              <% allImages.forEach((img, index) => { %>
                <div class="det-thumb <%= index === 0 ? 'active' : '' %>" onclick="changeDetailImage('<%= img %>', this)">
                  <img src="<%= img %>" alt="thumb" style="width: 100%; height: 100%; object-fit: cover; border-radius: 10px;">
                </div>
              <% }) %>
            </div>
            <div class="detail-dots" id="detailDots">
              <% allImages.forEach((_, index) => { %>
                <div class="detail-dot <%= index === 0 ? 'active' : '' %>"></div>
              <% }) %>
            </div>
          <% } %>
        </div>

        <!-- Detail Info -->
        <div class="detail-info">
          <div class="det-sku">SKU: <%= gemstone.sku %></div>
          <h1 class="det-title"><%= gemstone.name %></h1>
          <p class="det-cat">Category: <a href="/catalog?category=<%= gemstone.category_slug %>"><%= gemstone.category_name %> Gemstones</a></p>
          
          <div class="det-specs-grid">
            <div class="det-spec">
              <div class="spec-label">Ratna Type</div>
              <div class="spec-value"><%= gemstone.ratna_type || '—' %></div>
            </div>
            <div class="det-spec">
              <div class="spec-label">Carat Weight</div>
              <div class="spec-value"><%= gemstone.carat_weight || '—' %> ct</div>
            </div>
            <div class="det-spec">
              <div class="spec-label">Color Grade</div>
              <div class="spec-value"><%= gemstone.color_grade || '—' %></div>
            </div>
            <div class="det-spec">
              <div class="spec-label">Clarity</div>
              <div class="spec-value"><%= gemstone.clarity || '—' %></div>
            </div>
          </div>

          <div class="det-price-box">
            <div class="det-price">₹<%= parseFloat(gemstone.final_price).toLocaleString('en-IN') %></div>
            <div class="det-price-per">₹<%= parseFloat(gemstone.price_per_carat || (gemstone.final_price / gemstone.carat_weight)).toLocaleString('en-IN') %> per carat</div>
          </div>

          <button class="det-cert-btn">✦ <%= (gemstone.certificate_type || 'GIA').toUpperCase() %> Certified</button>

          <div class="det-cert-details">
            <h4>Certification Details</h4>
            <div class="det-cert-row">
              <span>Type</span>
              <span><%= gemstone.certificate_type || '—' %></span>
            </div>
            <div class="det-cert-row">
              <span>Certificate No.</span>
              <span><%= gemstone.certificate_number || '—' %></span>
            </div>
            <div class="det-cert-row">
              <span>Issued By</span>
              <span><%= gemstone.certificate_type || '—' %> Laboratories</span>
            </div>
            <div class="det-cert-row">
              <span>Origin</span>
              <span><%= gemstone.origin || '—' %></span>
            </div>
          </div>

          <!-- QR Verification Section -->
          <% if (gemstone.qr_code_data) { %>
            <div class="det-cert-details" style="margin-top: 1.5rem; text-align: center; background: #fff;">
              <h4 style="margin-bottom: 1rem;">Authentication QR</h4>
              <div style="display: inline-block; padding: 1rem; border: 1px solid var(--gold); border-radius: 12px; margin-bottom: 0.8rem;">
                <img src="<%= gemstone.qr_code_data %>" alt="Verification QR" style="width: 150px; display: block;">
              </div>
              <p style="font-size: 0.75rem; color: var(--txt-lt); line-height: 1.4; padding: 0 1rem;">
                Scan this QR code to verify this gemstone's authenticity and view its full digital trace on RatnaVeda.
              </p>
            </div>
          <% } %>
          
          <% if (gemstone.description) { %>
            <div style="margin-top: 2rem; padding: 1.5rem; background: var(--cream2); border-radius: var(--r-sm); border: 1px solid rgba(201,152,58,.1);">
              <h4 style="font-family: 'Playfair Display', serif; color: var(--ink); margin-bottom: 0.8rem;">About this Gemstone</h4>
              <p style="font-size: 0.9rem; color: var(--txt-lt); line-height: 1.7;"><%= gemstone.description %></p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function changeDetailImage(src, thumb) {
    const mainImgContainer = document.getElementById('detailMainImg');
    // Maintain the img tag and its styles
    mainImgContainer.innerHTML = `<img src="${src}" alt="Gemstone" style="max-width: 100%; max-height: 100%; object-fit: contain; position: relative; z-index: 2;">`;
    
    // Update active thumb
    document.querySelectorAll('.det-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
    
    // Update dots
    const index = Array.from(thumb.parentNode.children).indexOf(thumb);
    document.querySelectorAll('.detail-dot').forEach((d, i) => {
        d.classList.toggle('active', i === index);
    });
}
</script>

